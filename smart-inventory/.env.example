APP_KEY=
APP_DEBUG=true
APP_URL=https://flowventory-production.up.railway.app
ASSET_URL=https://flowventory-production.up.railway.app

CACHE_STORE=file

# Trust all proxies for X-Forwarded headers (Railway, LoadBalancer, CDN, etc)
TRUSTED_PROXIES=*
TRUSTED_HEADERS=X_FORWARDED_FOR,X_FORWARDED_PROTO,X_FORWARDED_PORT,X_FORWARDED_HOST

# Force HTTPS in URLs
FORCE_HTTPS=true

DB_CONNECTION=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=